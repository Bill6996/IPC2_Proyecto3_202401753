<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ITGSA — @ViewData["Title"]</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <style>
        body { background: #f4f6f9; }
        .navbar-brand { font-weight: 700; letter-spacing: 1px; }
        .sidebar { min-height: calc(100vh - 56px); background: #1a3c5e; }
        .sidebar a { color: #cce4ff; text-decoration: none; display: block;
                     padding: 10px 20px; border-radius: 6px; margin: 2px 8px; }
        .sidebar a:hover, .sidebar a.active { background: #2e6da4; color: #fff; }
        .sidebar .section-title { color: #6ea8d8; font-size: .75rem;
                                   text-transform: uppercase; padding: 14px 20px 4px; }
        .main-content { padding: 2rem; }
        .card { border: none; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,.08); }
        pre.xml-response { background:#1e1e1e; color:#d4d4d4;
                           padding:1rem; border-radius:8px; font-size:.85rem;
                           max-height:300px; overflow-y:auto; }
    </style>
</head>
<body>
<nav class="navbar navbar-dark bg-primary px-3">
    <a class="navbar-brand" href="/">
        <i class="bi bi-shop-window me-2"></i>ITGSA Sistema
    </a>
    <span class="text-white-50 small">Industria Típica Guatemalteca S.A.</span>
</nav>

<div class="d-flex">
    <!-- Sidebar -->
    <div class="sidebar" style="width:230px; flex-shrink:0;">
        <div class="section-title">General</div>
        <a href="/"><i class="bi bi-house me-2"></i>Inicio</a>
        <a href="/Reset"><i class="bi bi-arrow-counterclockwise me-2"></i>Resetear datos</a>

        <div class="section-title">Archivos</div>
        <a href="/Configuracion"><i class="bi bi-gear me-2"></i>Cargar config.xml</a>
        <a href="/Transacciones"><i class="bi bi-file-earmark-arrow-up me-2"></i>Cargar transac.xml</a>

        <div class="section-title">Peticiones</div>
        <a href="/EstadoCuenta"><i class="bi bi-person-lines-fill me-2"></i>Estado de cuenta</a>
        <a href="/Ingresos"><i class="bi bi-bar-chart-fill me-2"></i>Ingresos por banco</a>

        <div class="section-title">Otro</div>
        <a href="/Ayuda"><i class="bi bi-question-circle me-2"></i>Ayuda</a>
    </div>

    <!-- Contenido -->
    <div class="main-content flex-grow-1">
        @RenderBody()
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>