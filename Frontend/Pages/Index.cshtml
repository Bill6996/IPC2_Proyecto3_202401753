@page
@model IndexModel
@{ ViewData["Title"] = "Inicio"; }

<h2 class="mb-4"><i class="bi bi-house-fill text-primary me-2"></i>Panel de Control</h2>

<div class="row g-4">
    <div class="col-md-6 col-lg-4">
        <div class="card p-4 text-center">
            <i class="bi bi-gear-fill fs-1 text-primary mb-2"></i>
            <h5>Cargar Configuración</h5>
            <p class="text-muted small">Ingresa clientes y bancos al sistema.</p>
            <a href="/Configuracion" class="btn btn-primary btn-sm">Ir</a>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="card p-4 text-center">
            <i class="bi bi-file-earmark-arrow-up-fill fs-1 text-success mb-2"></i>
            <h5>Cargar Transacciones</h5>
            <p class="text-muted small">Registra facturas y pagos.</p>
            <a href="/Transacciones" class="btn btn-success btn-sm">Ir</a>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="card p-4 text-center">
            <i class="bi bi-person-lines-fill fs-1 text-info mb-2"></i>
            <h5>Estado de Cuenta</h5>
            <p class="text-muted small">Consulta saldos y transacciones.</p>
            <a href="/EstadoCuenta" class="btn btn-info btn-sm text-white">Ir</a>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="card p-4 text-center">
            <i class="bi bi-bar-chart-fill fs-1 text-warning mb-2"></i>
            <h5>Ingresos por Banco</h5>
            <p class="text-muted small">Gráfica de pagos por banco.</p>
            <a href="/Ingresos" class="btn btn-warning btn-sm">Ir</a>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="card p-4 text-center">
            <i class="bi bi-arrow-counterclockwise fs-1 text-danger mb-2"></i>
            <h5>Resetear Datos</h5>
            <p class="text-muted small">Limpia toda la base de datos.</p>
            <a href="/Reset" class="btn btn-danger btn-sm">Resetear</a>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="card p-4 text-center">
            <i class="bi bi-question-circle-fill fs-1 text-secondary mb-2"></i>
            <h5>Ayuda</h5>
            <p class="text-muted small">Documentación del sistema.</p>
            <a href="/Ayuda" class="btn btn-secondary btn-sm">Ver</a>
        </div>
    </div>
</div>