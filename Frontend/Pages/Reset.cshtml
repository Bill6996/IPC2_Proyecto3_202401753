@page
@model ResetModel
@{ ViewData["Title"] = "Resetear Datos"; }

<h2 class="mb-4"><i class="bi bi-arrow-counterclockwise text-danger me-2"></i>Resetear Datos del Sistema</h2>

<div class="card p-4" style="max-width:500px;">
    <p class="text-muted">Esta acción eliminará <strong>todos</strong> los clientes, bancos, facturas
       y pagos del sistema. No se puede deshacer.</p>
    <form method="post">
        <button type="submit" class="btn btn-danger">
            <i class="bi bi-trash me-1"></i>Confirmar Reset
        </button>
        <a href="/" class="btn btn-secondary ms-2">Cancelar</a>
    </form>
    @if (Model.Mensaje != null)
    {
        <div class="alert alert-success mt-3">@Model.Mensaje</div>
    }
</div>