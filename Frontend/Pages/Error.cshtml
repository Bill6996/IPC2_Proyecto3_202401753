@page "/Error"
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

<div class="text-center py-5">
    <i class="bi bi-exclamation-triangle-fill text-warning" style="font-size:5rem;"></i>
    <h1 class="mt-3">Ocurrió un error</h1>
    <p class="text-muted">No se pudo conectar con el backend o la página no existe.</p>
    <div class="mt-3">
        <a href="/" class="btn btn-primary me-2">
            <i class="bi bi-house me-1"></i>Ir al inicio
        </a>
        <a href="http://localhost:5001/swagger" target="_blank" class="btn btn-outline-secondary">
            <i class="bi bi-code-slash me-1"></i>Verificar API
        </a>
    </div>
    <div class="mt-4 text-muted small">
        Asegúrate de que el Backend esté corriendo en
        <code>http://localhost:5001</code>
    </div>
</div>