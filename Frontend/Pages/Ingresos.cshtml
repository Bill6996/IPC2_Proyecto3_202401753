@page
@model IngresosModel
@{ ViewData["Title"] = "Ingresos por Banco"; }

<h2 class="mb-4"><i class="bi bi-bar-chart-fill text-warning me-2"></i>Ingresos por Banco</h2>

<div class="card p-4 mb-4" style="max-width:400px;">
    <form method="get">
        <div class="row g-2 align-items-end">
            <div class="col">
                <label class="form-label fw-bold">Mes</label>
                <select name="mes" class="form-select">
                    @for (int m = 1; m <= 12; m++)
                    {
                        <option value="@m" selected="@(m == Model.Mes)">
                            @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)
                        </option>
                    }
                </select>
            </div>
            <div class="col">
                <label class="form-label fw-bold">Año</label>
                <input type="number" name="anio" value="@Model.Anio" class="form-control" min="2020" max="2099"/>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-warning">Ver</button>
            </div>
        </div>
    </form>
</div>

@if (Model.Datos != null && Model.Datos.Any())
{
    <div class="card p-4" style="max-width:800px;">
        <canvas id="chartIngresos" height="120"></canvas>
    </div>
}

@section Scripts {
<script>
const datos  = @Html.Raw(Model.ChartJson ?? "[]");
if (datos.length > 0) {
    const labels  = datos.map(d => d.nombre);
    const meses   = datos[0].meses;
    const colors  = ['#0d6efd','#fd7e14','#6c757d','#198754','#dc3545'];

    const datasets = meses.map((m, i) => ({
        label: `${m.mes.toString().padStart(2,'0')}/${m.anio}`,
        data : datos.map(b => b.meses[i].total / 1000),
        backgroundColor: colors[i % colors.length]
    }));

    new Chart(document.getElementById('chartIngresos'), {
        type: 'bar',
        data: { labels, datasets },
        options: {
            responsive: true,
            plugins: {
                title: { display: true,
                         text: `Ingresos por banco — Miles de Quetzales` }
            },
            scales: {
                y: { title: { display: true, text: 'Miles de Q.' } }
            }
        }
    });
}
</script>
}